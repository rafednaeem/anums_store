# Site
NEXT_PUBLIC_SITE_URL=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_WRITE_TOKEN=         # Used by admin dashboard to update stock (server-only; do NOT prefix with NEXT_PUBLIC_)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # Used by admin dashboard (server-only; do NOT prefix with NEXT_PUBLIC_)

# Payment Gateways
SAFEPAY_SECRET=              # Used for both Safepay API auth AND webhook HMAC verification
CASHMAAL_API_KEY=            # Cashmaal API authentication key
CASHMAAL_WEB_ID=             # Cashmaal merchant website ID
CASHMAAL_IPN_KEY=            # Cashmaal IPN verification key
CASHMAAL_SECRET=             # Legacy Cashmaal webhook HMAC verification secret

# Analytics
NEXT_PUBLIC_GA_ID=

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Notifications (Order alerts)
WHATSAPP_CLOUD_API_TOKEN=   # Meta WhatsApp Cloud API access token (server-only)
WHATSAPP_PHONE_NUMBER_ID=   # WhatsApp Business phone number ID (server-only)
NOTIFICATION_PHONE=         # Phone number to receive order alerts (server-only)
RESEND_API_KEY=            # Resend API key for order confirmation emails (server-only)
NOTIFICATION_EMAIL=        # From address for confirmation emails, e.g. "Anums Store <orders@anumsstore.pk>" (server-only)
